page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', 'PingFang SC', sans-serif;
  color: #1a1a2e;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

view, text, scroll-view, input, textarea, button, image {
  box-sizing: border-box;
}

.page-container {
  padding: 0 0 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #eef1ff 0%, #f5f6fa 15%);
}

.page-header {
  padding: 40rpx 36rpx 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: -0.5rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #8b8fa3;
  margin-top: 8rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 36rpx;
  margin: 0 36rpx 24rpx;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 0;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.06), rgba(168, 85, 247, 0.06));
  transition: height 0.3s ease;
}

.card-hover {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 36rpx;
  margin: 0 36rpx 24rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 8rpx rgba(26, 26, 46, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #ffffff;
  font-weight: 600;
  border-radius: 20rpx;
  padding: 28rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  line-height: 1.4;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 1;
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.2);
}

.btn-primary[disabled] {
  background: linear-gradient(135deg, #a5b4fc, #818cf8);
  box-shadow: none;
  opacity: 0.6;
}

.btn-outline {
  background: #ffffff;
  color: #6366f1;
  font-weight: 600;
  border-radius: 20rpx;
  padding: 28rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
  border: 3rpx solid #6366f1;
  line-height: 1.4;
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.btn-outline:active {
  background: #eef2ff;
  transform: scale(0.96);
}

.btn-ghost {
  background: transparent;
  color: #6366f1;
  font-weight: 500;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  line-height: 1.4;
}

.btn-ghost:active {
  background: #eef2ff;
}

.input-field {
  width: 100%;
  border: 2rpx solid #d1d5e0;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  background: #ffffff;
  color: #1a1a2e;
  line-height: 1.6;
  font-weight: 500;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
}

.input-field:focus {
  border-color: #6366f1;
  background: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(99, 102, 241, 0.12);
}

input::placeholder,
textarea::placeholder {
  color: #b0b4c8;
  font-weight: 400;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.tag-blue {
  background: #eef2ff;
  color: #4f46e5;
}

.tag-purple {
  background: #faf5ff;
  color: #7c3aed;
}

.tag-green {
  background: #ecfdf5;
  color: #059669;
}

.tag-orange {
  background: #fff7ed;
  color: #ea580c;
}

.tag-red {
  background: #fef2f2;
  color: #dc2626;
}

.tag-gold {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #92400e;
}

.gradient-primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
}

.gradient-warm {
  background: linear-gradient(135deg, #f59e0b, #ef4444);
}

.gradient-cool {
  background: linear-gradient(135deg, #06b6d4, #6366f1);
}

.gradient-primary-text {
  background: linear-gradient(135deg, #6366f1, #a855f7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #6366f1;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.text-primary {
  color: #6366f1;
}

.text-accent {
  color: #a855f7;
}

.text-gray-400 {
  color: #a0a3bd;
}

.text-gray-500 {
  color: #8b8fa3;
}

.text-gray-600 {
  color: #6b7085;
}

.text-gray-700 {
  color: #4a4d64;
}

.text-gray-800 {
  color: #2d3047;
}

.text-white {
  color: #ffffff;
}

.bg-primary-50 {
  background-color: #eef2ff;
}

.bg-primary-500 {
  background-color: #6366f1;
}

.bg-gray-50 {
  background-color: #f8f9fc;
}

.bg-gray-100 {
  background-color: #eef0f6;
}

.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.gap-8 {
  gap: 8rpx;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.gap-24 {
  gap: 24rpx;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

.shrink-0 {
  flex-shrink: 0;
}

.text-center {
  text-align: center;
}

.font-bold {
  font-weight: 800;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

.overflow-hidden {
  overflow: hidden;
}

.whitespace-pre-wrap {
  white-space: pre-wrap;
}

.divider {
  height: 1rpx;
  background: #eef0f6;
  margin: 24rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  align-items: center;
}

.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #a5b4fc;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: 0s;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.16s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.32s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0.4);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.skeleton {
  background: linear-gradient(90deg, #eef0f6 25%, #f5f6fa 50%, #eef0f6 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}

.number-display {
  font-variant-numeric: tabular-nums;
  font-feature-settings: 'tnum';
}
