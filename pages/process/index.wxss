.current-phase-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 32rpx 36rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
}

.current-phase-left {
  flex-shrink: 0;
}

.current-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #fbbf24;
  box-shadow: 0 0 0 8rpx rgba(251, 191, 36, 0.25);
  animation: dotBlink 2s ease-in-out infinite;
}

@keyframes dotBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.current-phase-content {
  flex: 1;
}

.current-phase-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.current-phase-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
  display: block;
  margin-top: 4rpx;
}

.current-phase-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-top: 4rpx;
}

.timeline-section {
  padding: 0 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 24rpx;
}
