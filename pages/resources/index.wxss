.page-header {
  padding: 40rpx 36rpx 24rpx;
}

.search-bar {
  margin: 0 36rpx 24rpx;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 30rpx;
  color: #a5b4fc;
  z-index: 1;
  pointer-events: none;
}

.search-input {
  width: 100%;
  height: 84rpx;
  border: 2rpx solid #e5e7f0;
  border-radius: 42rpx;
  padding: 0 32rpx 0 68rpx;
  font-size: 28rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(99, 102, 241, 0.06);
  transition: border-color 0.2s, box-shadow 0.2s;
}

.search-input:focus {
  border-color: #818cf8;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1), 0 2rpx 12rpx rgba(99, 102, 241, 0.08);
}

.tab-bar {
  margin: 0 36rpx 28rpx;
  background: #eef0f6;
  border-radius: 40rpx;
  padding: 6rpx;
}

.tab-bar-inner {
  display: inline-flex;
  gap: 4rpx;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #8b8fa3;
  transition: all 0.25s ease;
}

.tab-active {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
}

.filter-scroll {
  white-space: nowrap;
  margin: 0 36rpx 24rpx;
}

.filter-tags {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.filter-tag {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #f8f9fc;
  color: #6b7085;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.filter-active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #c7d2fe;
}

.space-y {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.uni-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 0;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.uni-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(26, 26, 46, 0.06);
}

.uni-card-inner {
  padding: 32rpx 32rpx 32rpx 40rpx;
}

.uni-card-stripe {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.stripe-indigo {
  background: linear-gradient(180deg, #6366f1, #818cf8);
}

.stripe-purple {
  background: linear-gradient(180deg, #8b5cf6, #a78bfa);
}

.stripe-amber {
  background: linear-gradient(180deg, #f59e0b, #fbbf24);
}

.stripe-emerald {
  background: linear-gradient(180deg, #10b981, #34d399);
}

.stripe-rose {
  background: linear-gradient(180deg, #f43f5e, #fb7185);
}

.stripe-cyan {
  background: linear-gradient(180deg, #06b6d4, #22d3ee);
}

.uni-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.uni-logo {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fc;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.uni-header-text {
  flex: 1;
  min-width: 0;
}

.uni-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.uni-arrow {
  font-size: 22rpx;
  color: #c7d2fe;
  flex-shrink: 0;
}

.uni-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.uni-motto {
  font-size: 22rpx;
  color: #a0a3bd;
  margin-top: 4rpx;
  display: block;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 24rpx;
  font-size: 24rpx;
}

.info-cell {
  display: flex;
  gap: 4rpx;
}

.info-label {
  color: #a0a3bd;
  flex-shrink: 0;
}

.info-value {
  color: #4a4d64;
}

.full-width {
  grid-column: span 2;
}

.uni-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 20rpx;
}

.uni-card-footer {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eef0f6;
  text-align: center;
}

.uni-card-hint {
  font-size: 22rpx;
  color: #a5b4fc;
}

.list-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.list-dot {
  color: #a5b4fc;
  flex-shrink: 0;
  font-size: 28rpx;
}

.list-num {
  color: #6366f1;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  min-width: 36rpx;
}

.formula-box {
  background: linear-gradient(135deg, #eef2ff, #faf5ff);
  border: 2rpx solid #e0e7ff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.formula-main {
  font-size: 28rpx;
  font-family: monospace;
  color: #4f46e5;
  font-weight: 600;
  display: block;
}

.formula-sub {
  font-size: 24rpx;
  color: #8b8fa3;
  display: block;
  margin-top: 8rpx;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.score-item {
  background: linear-gradient(135deg, #f8f9fc, #eef2ff);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 2rpx solid #eef0f6;
}

.score-year {
  font-size: 22rpx;
  color: #8b8fa3;
  display: block;
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #4f46e5;
  display: block;
  font-variant-numeric: tabular-nums;
}

.score-label {
  font-size: 20rpx;
  color: #a0a3bd;
  display: block;
  margin-top: 4rpx;
}

.score-note {
  font-size: 22rpx;
  color: #a0a3bd;
  display: block;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #eef0f6;
}

.faq-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  overflow: hidden;
}

.faq-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.faq-q-wrap {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex: 1;
}

.faq-q-icon {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.faq-q-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
}

.faq-arrow {
  font-size: 24rpx;
  color: #a5b4fc;
  transition: transform 0.3s ease;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.faq-arrow-open {
  transform: rotate(90deg);
}

.faq-body {
  padding: 0 32rpx 28rpx;
  overflow: hidden;
}

.faq-a-text {
  font-size: 28rpx;
  color: #6b7085;
  line-height: 1.7;
  padding-top: 16rpx;
  border-top: 1rpx solid #eef0f6;
}

.policy-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

.policy-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 20rpx;
}

.line-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

.line-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
