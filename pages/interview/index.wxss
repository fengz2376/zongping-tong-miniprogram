.page-header {
  padding: 40rpx 36rpx 24rpx;
}

.tab-bar {
  margin: 0 36rpx 24rpx;
  background: #eef0f6;
  border-radius: 999rpx;
  padding: 6rpx;
}

.tab-bar-inner {
  display: inline-flex;
  gap: 4rpx;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #8b8fa3;
  transition: all 0.25s ease;
}

.tab-active {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.35);
  font-weight: 600;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #4a4d64;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.placeholder { color: #a0a3bd; }
.picker-arrow { font-size: 20rpx; color: #a0a3bd; }
.textarea { min-height: 200rpx; padding: 28rpx 32rpx; }

.chat-card {
  display: flex;
  flex-direction: column;
  min-height: 800rpx;
}

.chat-scroll {
  height: 600rpx;
}

.chat-input-area {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #eef0f6;
  align-items: center;
}

.chat-input {
  flex: 1;
  min-height: 80rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.send-btn {
  flex-shrink: 0;
  padding: 20rpx 40rpx !important;
  font-size: 28rpx !important;
  line-height: 1.2 !important;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
}

.msg-right {
  justify-content: flex-end;
}

.msg-left {
  display: flex;
  margin-bottom: 20rpx;
}

.msg-bubble {
  max-width: 80%;
  border-radius: 28rpx 28rpx 28rpx 28rpx;
  padding: 20rpx 28rpx;
}

.bubble-user {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  border-radius: 28rpx 28rpx 8rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.2);
}

.bubble-assistant {
  background: #f3f4f8;
  border-radius: 28rpx 28rpx 28rpx 8rpx;
}

.loading-bubble {
  padding: 24rpx 28rpx;
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #2d3047;
  white-space: pre-wrap;
  word-break: break-all;
}

.space-y {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.info-label {
  font-size: 26rpx;
}

.info-value {
  font-size: 26rpx;
}

.category-scroll {
  white-space: nowrap;
  margin: 0 36rpx 24rpx;
}

.category-tags {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.category-tag {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f3f4f8;
  color: #6b7085;
  font-weight: 500;
  transition: all 0.2s ease;
}

.category-active {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.question-card {
  position: relative;
  overflow: hidden;
}

.question-card::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 0;
  bottom: 16rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
}

.question-card.cat-self-intro::before { background: linear-gradient(180deg, #6366f1, #818cf8); }
.question-card.cat-motivation::before { background: linear-gradient(180deg, #f59e0b, #fbbf24); }
.question-card.cat-academic::before { background: linear-gradient(180deg, #06b6d4, #22d3ee); }
.question-card.cat-critical-thinking::before { background: linear-gradient(180deg, #ef4444, #f87171); }
.question-card.cat-hot-topics::before { background: linear-gradient(180deg, #8b5cf6, #a78bfa); }
.question-card.cat-personal::before { background: linear-gradient(180deg, #10b981, #34d399); }
.question-card.cat-teamwork::before { background: linear-gradient(180deg, #ec4899, #f472b6); }
.question-card.cat-scenario::before { background: linear-gradient(180deg, #f97316, #fb923c); }
.question-card.cat-values::before { background: linear-gradient(180deg, #14b8a6, #2dd4bf); }
.question-card.cat-innovation::before { background: linear-gradient(180deg, #6366f1, #a855f7); }

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tip-check {
  color: #6366f1;
  flex-shrink: 0;
  margin-top: 2rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.star-item {
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.guide-card {
  border-left: 6rpx solid #6366f1;
}

.guide-card.type-985 {
  border-left-color: #f59e0b;
}

.guide-card.type-211 {
  border-left-color: #6366f1;
}
