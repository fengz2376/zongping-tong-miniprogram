.hero-section {
  position: relative;
  padding: 48rpx 36rpx 36rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 40%, #818cf8 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.hero-logo {
  font-size: 80rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 28rpx;
  flex-shrink: 0;
  backdrop-filter: blur(10px);
}

.hero-info {
  flex: 1;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.hero-motto {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.overview-card,
.interview-card,
.scores-card,
.majors-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04), 0 0 1rpx rgba(26, 26, 46, 0.08);
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.overview-text {
  font-size: 28rpx;
  color: #4a4d64;
  line-height: 1.8;
  display: block;
  margin-bottom: 24rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0f6;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 26rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #6b7085;
}

.meta-link {
  color: #6366f1;
  font-weight: 500;
}

.interview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.interview-cell {
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.interview-label {
  font-size: 22rpx;
  color: #a0a3bd;
  display: block;
  margin-bottom: 6rpx;
}

.interview-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.pref-box {
  background: linear-gradient(135deg, #eef2ff, #faf5ff);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.pref-label {
  font-size: 22rpx;
  color: #6366f1;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.pref-text {
  font-size: 26rpx;
  color: #4a4d64;
  line-height: 1.6;
  display: block;
}

.feature-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.score-table {
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #eef0f6;
}

.score-table-header {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  background: #f8f9fc;
  padding: 16rpx 0;
}

.score-th {
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #8b8fa3;
}

.score-table-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  padding: 20rpx 0;
  border-top: 1rpx solid #eef0f6;
}

.score-td {
  text-align: center;
  font-size: 28rpx;
  color: #4a4d64;
}

.score-year-text {
  color: #8b8fa3;
  font-weight: 500;
}

.score-highlight {
  font-weight: 700;
  color: #4f46e5;
}

.score-note {
  font-size: 22rpx;
  color: #a0a3bd;
  display: block;
  margin-top: 16rpx;
  text-align: center;
}

.major-groups {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.major-group {
  background: #f8f9fc;
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #eef0f6;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.group-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.group-code {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.group-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
}

.group-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.group-score {
  font-size: 30rpx;
  font-weight: 800;
  color: #4f46e5;
}

.group-score-label {
  font-size: 20rpx;
  color: #a0a3bd;
}

.group-arrow {
  font-size: 20rpx;
  color: #a5b4fc;
  transition: transform 0.3s ease;
  margin-left: 4rpx;
}

.group-arrow-open {
  transform: rotate(90deg);
}

.group-body {
  padding: 0 28rpx 24rpx;
  border-top: 1rpx solid #eef0f6;
}

.group-scores-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  padding: 20rpx 0;
}

.group-score-item {
  text-align: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 6rpx;
}

.group-score-latest {
  background: linear-gradient(135deg, #eef2ff, #faf5ff);
  border: 2rpx solid #c7d2fe;
}

.gs-year {
  font-size: 22rpx;
  color: #8b8fa3;
  display: block;
  margin-bottom: 4rpx;
}

.gs-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #4f46e5;
  display: block;
}

.major-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.major-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.major-dot {
  color: #a5b4fc;
  font-size: 24rpx;
  flex-shrink: 0;
}

.major-name {
  font-size: 26rpx;
  color: #4a4d64;
}
