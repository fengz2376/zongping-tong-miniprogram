.header {
  padding: 48rpx 40rpx 16rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.app-title {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  letter-spacing: -1rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #8b8fa3;
  display: block;
  margin-top: 4rpx;
}

.header-profile {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(26, 26, 46, 0.06);
  transition: transform 0.15s ease;
}

.header-profile:active {
  transform: scale(0.92);
}

.profile-icon {
  font-size: 36rpx;
}

.phase-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 16rpx 40rpx 28rpx;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04);
  border-left: 8rpx solid #6366f1;
  transition: transform 0.15s ease;
}

.phase-banner:active {
  transform: scale(0.98);
  background: #f8f9fc;
}

.phase-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #6366f1;
  flex-shrink: 0;
  box-shadow: 0 0 0 6rpx rgba(99, 102, 241, 0.15);
}

.phase-content {
  flex: 1;
}

.phase-label {
  font-size: 22rpx;
  color: #8b8fa3;
  display: block;
}

.phase-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-top: 2rpx;
}

.phase-arrow {
  font-size: 32rpx;
  color: #a5b4fc;
  flex-shrink: 0;
}

.nav-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.nav-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(26, 26, 46, 0.04);
  transition: transform 0.15s ease;
  position: relative;
  overflow: hidden;
}

.nav-card:active {
  transform: scale(0.98);
}

.nav-process {
  border-left: 8rpx solid #6366f1;
}

.nav-resources {
  border-left: 8rpx solid #f59e0b;
}

.nav-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-process {
  background: linear-gradient(135deg, #eef2ff, #e0e7ff);
}

.icon-resources {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
}

.nav-emoji {
  font-size: 40rpx;
}

.nav-text {
  flex: 1;
}

.nav-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.nav-desc {
  font-size: 24rpx;
  color: #8b8fa3;
  display: block;
  margin-top: 4rpx;
}

.nav-arrow {
  font-size: 32rpx;
  color: #c7d2fe;
  flex-shrink: 0;
}

.section-title-bar {
  padding: 0 40rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.tools {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.tool-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx 12rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(26, 26, 46, 0.03);
  transition: transform 0.15s ease;
}

.tool-item:active {
  transform: scale(0.95);
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.icon-indigo {
  background: linear-gradient(135deg, #eef2ff, #e0e7ff);
}

.icon-purple {
  background: linear-gradient(135deg, #faf5ff, #ede9fe);
}

.icon-emerald {
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
}

.icon-amber {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
}

.tool-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a4d64;
}

.insight-card {
  margin: 0 40rpx 60rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #2d3047, #312e81);
  border-radius: 28rpx;
  position: relative;
  overflow: hidden;
}

.insight-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.25), transparent 70%);
  pointer-events: none;
}

.insight-number {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
  position: relative;
}

.insight-desc {
  display: block;
  font-size: 24rpx;
  color: #a0a3bd;
  line-height: 1.6;
  position: relative;
}

.insight-action {
  display: inline-block;
  margin-top: 20rpx;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  border-radius: 16rpx;
  position: relative;
}

.insight-action text {
  font-size: 24rpx;
  font-weight: 700;
  color: #1a1a2e;
}
