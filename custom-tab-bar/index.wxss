.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1rpx solid rgba(99, 102, 241, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-width: 100rpx;
  padding: 8rpx 0;
  position: relative;
}

.tab-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a0a3bd;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-icon text {
  font-size: 48rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-icon-active {
  color: #6366f1;
  transform: scale(1.08);
}

.tab-icon-active text {
  transform: scale(1.1);
}

.tab-dot {
  width: 0;
  height: 8rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: absolute;
  bottom: 0;
}

.tab-dot-active {
  width: 16rpx;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #a0a3bd;
  transition: all 0.3s ease;
}

.tab-label-active {
  color: #6366f1;
  font-weight: 600;
}
